      "parameters": {
        "jsCode": "const item = $input.item;\nconst binaries = item.binary || {};\nconst keys = Object.keys(binaries);\n\n// 如果沒有任何檔案，就直接回傳原本這個 item\nif (keys.length === 0) {\n  return item;\n}\n\n// 有檔案時：為每個檔案建立一個新 item，binary 名稱統一為 data\nreturn keys.map(key => ({\n  json: {\n    ...item.json,\n    sourceKey: key, // 可選：記錄原本的 key 名稱\n  },\n  binary: {\n    data: binaries[key],\n  },\n}));"
      },
