    {
      "parameters": {
        "jsCode": "const allItems = $input.all();\nlet allChunks = [];\n\nfor (let i = 0; i < allItems.length; i++) {\n  const binaryData = await this.helpers.getBinaryDataBuffer(i, 'data');\n  const rawText = binaryData.toString('utf8');\n\n  let lawName = \"未知法規\";\n  let contentText = \"\";\n\n  try {\n    const payload = JSON.parse(rawText);\n    lawName = payload.lawName || \"未知法規\";\n    contentText = payload.content || \"\";\n  } catch (e) {\n    contentText = rawText;\n  }\n\n  const articleRegex = /(第\\s*\\d+(?:-\\d+)?\\s*條)/g;\n  const parts = contentText.split(articleRegex);\n\n  for (let j = 1; j < parts.length; j += 2) {\n    const articleTitle = parts[j];\n    const articleContent = parts[j + 1];\n\n    if (articleContent && articleContent.trim().length > 0) {\n      const trimmedContent = articleContent.trim();\n\n      // 精準過濾：僅當內容完全為以下幾種形式時才跳過\n      if (\n        trimmedContent === \"(已刪除)\" || \n        trimmedContent === \"（刪除）\" || \n        trimmedContent === \"(刪除)\" ||\n        trimmedContent === \"（刪除）\"\n      ) {\n        continue;\n      }\n\n      allChunks.push({\n        json: {\n          pageContent: `${lawName} ${articleTitle}：${trimmedContent}`,\n          metadata: {\n            source: lawName,\n            article: articleTitle,\n            type: \"official_law\"\n          }\n        }\n      });\n    }\n  }\n}\n\nreturn allChunks;"
      },
      "type": "n8n-nodes-base.code",
      "typeVersion": 2,
