    {
      "parameters": {
        "jsCode": "return $input.all().map(item => {\n  // 從當前項目（已合併 lawName 與 lawContent）中提取資料\n  const rawText = item.json.lawContent;\n  const lawName = item.json.lawName || \"未知法規\"; \n  \n  const cleanedText = rawText\n    ? rawText\n        .replace(/\\[LawSingle\\.aspx\\?pcode=[^\\]]*\\]/g, \"\")\n        .replace(/\\s+/g, \" \")\n        .trim()\n    : \"\";\n  \n  return { \n    json: { \n      lawName: lawName,\n      cleanedText: cleanedText \n    } \n  };\n});"
      },
