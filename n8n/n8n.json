      "parameters": {
        "jsCode": "return items.map(item => {\n  // 將法規名稱與內容打包在一起\n  const payload = {\n    lawName: item.json.lawName || \"未知法規\",\n    content: item.json.cleanedText\n  };\n  \n  const content = JSON.stringify(payload); // 轉換打包後的物件\n  \n  return {\n    json: item.json,\n    binary: {\n      data: {\n        data: Buffer.from(content).toString('base64'),\n        mimeType: 'application/json',\n        fileName: 'data.json' // 這裡你依然可以為了方便維持 data.json\n      }\n    }\n  };\n});"
      },
